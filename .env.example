# Authentication (pick one):
#   Option 1 (recommended): Leave this empty and use your Claude Code subscription
#     via `claude login`. Scans are covered by your existing subscription.
#   Option 2: Set an API key below. Scans will be billed to your Anthropic API account.
ANTHROPIC_API_KEY=

# Backend behavior
CLAUDE_OPTIMIZE_MODEL=claude-opus-4-6
CLAUDE_OPTIMIZE_MAX_TURNS=12
CLAUDE_OPTIMIZE_MAX_CONCURRENT_SCANS=2
CLAUDE_OPTIMIZE_SCAN_TTL_SECONDS=3600
CLAUDE_OPTIMIZE_SKIP_PERMISSIONS=false

# Local security and CORS
CLAUDE_OPTIMIZE_ALLOWED_PATHS=
CLAUDE_OPTIMIZE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173